  "keyFeatures": [
    "Create and customize professional invoices with your branding",
    "Send invoices by email directly from the platform",
    "Accept online payments via multiple payment gateways",
    "Automate recurring invoices and payment reminders",
    "Track invoice status — draft, sent, viewed, paid, overdue",
    "Manage client contacts and payment history",
    "Generate financial reports (revenue, outstanding, tax summaries)",
    "Multi-currency and multi-tax support",
    "REST API for programmatic invoice management",
    "Webhooks for real-time event notifications"
  ],
  "publicApiSurface": [
    "POST /v1/invoices — Create an invoice",
    "GET /v1/invoices/{id} — Retrieve an invoice",
    "PUT /v1/invoices/{id} — Update an invoice",
    "DELETE /v1/invoices/{id} — Delete an invoice",
    "POST /v1/invoices/{id}/send — Send invoice to client",
    "GET /v1/clients — List clients",
    "POST /v1/clients — Create a client",
    "GET /v1/payments — List payments",
    "POST /v1/webhooks — Register a webhook endpoint",
    "GET /v1/reports/revenue — Revenue summary report"
  ]
